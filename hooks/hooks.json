{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/session-start\"",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}\" python3 -m recap.capture",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=\"${CLAUDE_PLUGIN_ROOT}\" python3 -m recap.autorecap",
            "timeout": 180,
            "async": true
          }
        ]
      }
    ]
  }
}
